{
    "alias": "All ACs - Set Low Fan",
    "description": "Sets fan to Low on all ACs that are currently running (not off/unavailable)",
    "sequence": [
        {
            "if": [
                {
                    "condition": "not",
                    "conditions": [
                        {
                            "condition": "state",
                            "entity_id": "climate.ac_01",
                            "state": [
                                "off",
                                "unavailable",
                                "unknown"
                            ]
                        }
                    ]
                }
            ],
            "then": [
                {
                    "action": "climate.set_fan_mode",
                    "target": {
                        "entity_id": "climate.ac_01"
                    },
                    "data": {
