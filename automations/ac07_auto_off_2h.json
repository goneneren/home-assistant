{
    "id": "ac07_auto_off_2h",
    "alias": "AC_07 Auto-off after 2h (08:00-21:00)",
    "description": "If AC_07 is turned on between 09:00 and 21:00, turn it off after 2 hours",
    "triggers": [
        {
            "platform": "state",
            "entity_id": "climate.ac_07",
            "from": "off",
            "not_to": [
                "off",
                "unavailable",
                "unknown"
            ]
        },
        {
            "trigger": "time",
            "at": "08:00:00"
        }
    ],
    "conditions": [
        {
            "condition": "time",
            "after": "08:00:00",
            "before": "21:00:00"
        }
    ],
    "actions": [
        {
            "delay": {
                "hours": 2
            }
        },
        {
            "condition": "not",
            "conditions": [
                {
                    "condition": "state",
                    "entity_id": "climate.ac_07",
                    "state": "off"
                }
            ]
        },
        {
            "target": {
                "entity_id": "climate.ac_07"
            },
            "action": "climate.turn_off"
        }
    ],
    "mode": "restart"
}
