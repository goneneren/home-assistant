{
  "id": "ac04_night_auto_26",
  "alias": "AC_04 Night Mode - Auto 26C (21:00-09:00)",
  "description": "Between 21:00-09:00, if AC is on and fan is not Low or Quiet, set fan to Auto and temp to 26C after 5 min",
  "triggers": [
    {
      "trigger": "state",
      "entity_id": "climate.ac_04",
      "from": "off",
      "not_to": ["off", "unavailable", "unknown"]
    },
    {
      "trigger": "state",
      "entity_id": "climate.ac_04",
      "attribute": "fan_mode",
      "not_to": ["Low", "Quiet", null]
    }
  ],
  "conditions": [
    {"condition": "time", "after": "21:00:00", "before": "09:00:00"},
    {
      "condition": "not",
      "conditions": [{"condition": "state", "entity_id": "climate.ac_04", "state": "off"}]
    },
    {
      "condition": "not",
      "conditions": [{"condition": "state", "entity_id": "climate.ac_04", "attribute": "fan_mode", "state": "Low"}]
    },
    {
      "condition": "not",
      "conditions": [{"condition": "state", "entity_id": "climate.ac_04", "attribute": "fan_mode", "state": "Quiet"}]
    }
  ],
  "actions": [
    {"delay": {"minutes": 5}},
    {
      "condition": "and",
      "conditions": [
        {"condition": "not", "conditions": [{"condition": "state", "entity_id": "climate.ac_04", "state": "off"}]},
        {"condition": "not", "conditions": [{"condition": "state", "entity_id": "climate.ac_04", "attribute": "fan_mode", "state": "Low"}]},
        {"condition": "not", "conditions": [{"condition": "state", "entity_id": "climate.ac_04", "attribute": "fan_mode", "state": "Quiet"}]}
      ]
    },
    {
      "action": "climate.set_fan_mode",
      "target": {"entity_id": "climate.ac_04"},
      "data": {"fan_mode": "Auto"}
    },
    {
      "action": "climate.set_temperature",
      "target": {"entity_id": "climate.ac_04"},
      "data": {"temperature": 26}
    }
  ],
  "mode": "restart"
}
